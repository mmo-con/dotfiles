#!/bin/sh

if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    printf '%s\n' 'SSH_AUTH_SOCK is not set; no session SSH agent is available' >&2
    exit 1
fi

set --
for key in "$HOME/.ssh/id_rsa" "$HOME/.ssh/id_ed25519"; do
    [ -r "$key" ] && set -- "$@" "$key"
done

[ "$#" -gt 0 ] || exit 0

exec /usr/bin/env \
    SSH_ASKPASS="$HOME/.local/bin/ssh-askpass-wrapper" \
    SSH_ASKPASS_REQUIRE=force \
    /usr/bin/ssh-add "$@" </dev/null
